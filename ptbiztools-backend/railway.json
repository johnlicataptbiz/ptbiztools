{
  "$schema": "https://railway.com/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs", "npm"]
        },
        "build": {
          "cmds": [
            "npm ci",
            "npx prisma generate",
            "npm run build"
          ]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npm run start"
  }
}
