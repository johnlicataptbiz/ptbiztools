generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActionLog {
  id          String   @id @default(uuid())
  actionType  String
  description String
  metadata    Json?
  userId      String?
  sessionId   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([actionType])
  @@index([createdAt])
  @@index([userId])
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  category  String
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Video {
  id        String   @id
  name      String   @unique
  data      Bytes
  mimeType  String   @default("video/mp4")
  size      Int
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  passwordHash String?
  role         String   @default("coach")
  teamSection  String?
  title        String?
  bio          String?  @db.Text
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  actionLogs         ActionLog[]
  loginEvents        LoginEvent[]
  coachingAnalyses   CoachingAnalysis[]
  pdfExports         PdfExport[]

  @@index([email])
  @@index([role])
}

model LoginEvent {
  id         String   @id @default(uuid())
  userId     String?
  success    Boolean  @default(true)
  rememberMe Boolean?
  sessionId  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([success])
}

model CoachingAnalysis {
  id                    String   @id @default(uuid())
  userId                String?
  sessionId             String?
  coachName             String?
  clientName            String?
  callDate              String?
  score                 Int
  outcome               String
  summary               String
  phaseScores           Json
  strengths             Json
  improvements          Json
  redFlags              Json
  deidentifiedTranscript String  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  pdfExports PdfExport[]

  @@index([userId])
  @@index([createdAt])
}

model PdfExport {
  id                String   @id @default(uuid())
  userId            String?
  coachingAnalysisId String?
  sessionId         String?
  coachName         String?
  clientName        String?
  callDate          String?
  score             Int?
  metadata          Json?
  createdAt         DateTime @default(now())

  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  coachingAnalysis CoachingAnalysis? @relation(fields: [coachingAnalysisId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([coachingAnalysisId])
  @@index([createdAt])
}
