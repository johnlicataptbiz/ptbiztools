generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActionLog {
  id          String   @id @default(uuid())
  actionType  String
  description String
  metadata    Json?
  userId      String?
  sessionId   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([actionType])
  @@index([createdAt])
  @@index([userId])
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  category  String
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Video {
  id        String   @id
  name      String   @unique
  data      Bytes
  mimeType  String   @default("video/mp4")
  size      Int
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  passwordHash String?
  role         String   @default("coach")
  teamSection  String?
  title        String?
  bio          String?  @db.Text
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  actionLogs ActionLog[]

  @@index([email])
  @@index([role])
}
