generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActionLog {
  id          String   @id @default(uuid())
  actionType  String
  description String
  metadata    Json?
  userId      String?
  sessionId   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([actionType])
  @@index([createdAt])
  @@index([userId])
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  slug      String?  @unique
  title     String
  content   String   @db.Text
  category  String
  source    String?
  version   String   @default("2026.02")
  checksum  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Video {
  id        String   @id
  name      String   @unique
  data      Bytes
  mimeType  String   @default("video/mp4")
  size      Int
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  passwordHash String?
  role         String   @default("coach")
  teamSection  String?
  title        String?
  bio          String?  @db.Text
  imageUrl     String?
  isActive     Boolean  @default(true)
  onboardingTourVersion String?
  onboardingTourCompletedAt DateTime?
  onboardingToolIntros Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  actionLogs         ActionLog[]
  loginEvents        LoginEvent[]
  coachingAnalyses   CoachingAnalysis[]
  pdfExports         PdfExport[]
  plImportSessions   PLImportSession[]
  plImportBatches    PLImportBatch[]

  @@index([email])
  @@index([role])
}

model LoginEvent {
  id         String   @id @default(uuid())
  userId     String?
  success    Boolean  @default(true)
  rememberMe Boolean?
  sessionId  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([success])
}

model CoachingAnalysis {
  id                    String   @id @default(uuid())
  userId                String?
  sessionId             String?
  coachName             String?
  clientName            String?
  callDate              String?
  score                 Int
  outcome               String
  summary               String
  phaseScores           Json
  strengths             Json
  improvements          Json
  redFlags              Json
  gradingVersion        String   @default("v1")
  deterministic         Json?
  criticalBehaviors     Json?
  confidence            Int?
  qualityGate           Json?
  evidence              Json?
  transcriptHash        String?
  deidentifiedTranscript String  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  pdfExports PdfExport[]

  @@index([userId])
  @@index([createdAt])
}

model PdfExport {
  id                String   @id @default(uuid())
  userId            String?
  coachingAnalysisId String?
  sessionId         String?
  coachName         String?
  clientName        String?
  callDate          String?
  score             Int?
  metadata          Json?
  createdAt         DateTime @default(now())

  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  coachingAnalysis CoachingAnalysis? @relation(fields: [coachingAnalysisId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([coachingAnalysisId])
  @@index([createdAt])
}

model PLImportSession {
  id                    String               @id @default(uuid())
  userId                String?
  status                String               @default("uploaded")
  sourceType            String
  sourceLabel           String?
  filename              String
  mimeType              String
  sizeBytes             Int
  parserVersion         String?
  mappingVersion        String?
  overallConfidence     Int                  @default(0)
  requiredFieldsComplete Boolean             @default(false)
  errorMessage          String?              @db.Text
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user                  User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  sourceFile            PLImportSourceFile?
  parseArtifact         PLImportParseArtifact?
  mapping               PLImportMapping?
  batchItems            PLImportBatchItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PLImportSourceFile {
  id             String          @id @default(uuid())
  importSessionId String         @unique
  data           Bytes
  sha256         String
  isCompressed   Boolean         @default(false)
  compression    String          @default("none")
  createdAt      DateTime        @default(now())

  importSession  PLImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model PLImportParseArtifact {
  id             String          @id @default(uuid())
  importSessionId String         @unique
  rawExtraction  Json
  qualitySignals Json
  createdAt      DateTime        @default(now())

  importSession  PLImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
}

model PLImportMapping {
  id             String          @id @default(uuid())
  importSessionId String         @unique
  autoMap        Json
  finalMap       Json
  mappedInput    Json
  fieldConfidence Json
  manualOverrides Json
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  importSession  PLImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
}

model PLImportBatch {
  id              String              @id @default(uuid())
  userId          String?
  name            String?
  programType     String              @default("mastermind")
  status          String              @default("draft")
  overallConfidence Int               @default(0)
  timelinePayload Json?
  warningSummary  Json?
  approvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           PLImportBatchItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PLImportBatchItem {
  id              String          @id @default(uuid())
  batchId         String
  importSessionId String
  periodLabel     String
  periodOrder     Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  batch           PLImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  importSession   PLImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)

  @@unique([batchId, importSessionId])
  @@unique([batchId, periodOrder])
  @@index([importSessionId])
  @@index([periodLabel])
}
